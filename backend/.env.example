# Listify — backend environment
# Copy this file to `.env` and fill in the values.

NODE_ENV=development
PORT=8080

# Comma-separated list of allowed CORS origins.
# REQUIRED in production — the server refuses to start without it.
CORS_ORIGINS=http://localhost:5173

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# From Firebase Console → Project Settings → Service Accounts.
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the full service-account JSON on a single line.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# This email is auto-promoted to admin on first login.
ADMIN_EMAIL=your-email@example.com

# ── SQLite ────────────────────────────────────────────────────────────────────
# Auto-created on first run. On Cloud Run use /tmp/catalog.db (ephemeral).
DB_PATH=./data/catalog.db

# ── Shopify harvester tuning (optional — defaults shown) ──────────────────────
SHOPIFY_MAX_PAGES=200
SHOPIFY_PAGE_DELAY_MS=250

# ── Gemini AI content generation ──────────────────────────────────────────────
# Powers /api/shopify/build: Body (HTML), SEO Description, Image Alt Text, and
# Product Category / Type. Get a key from https://aistudio.google.com/apikey
# If left BLANK, the build still runs — those AI fields are just left empty.
GEMINI_API_KEY=
# Cheapest capable model. Override only if you need a different tier.
# Note: gemini-2.0-flash was retired by Google (404) — use a 2.5 model.
GEMINI_MODEL=gemini-2.5-flash-lite
